<launch>
  <!-- RPLIDAR 雷达节点 -->
  <node name="rplidarNode" pkg="rplidar_ros" type="rplidarNode" output="screen">
    <param name="serial_port"         type="string" value="/dev/ttyUSB0"/>
    <param name="serial_baudrate"     type="int"    value="256000"/>
    <param name="frame_id"            type="string" value="laser_link"/>
    <param name="inverted"            type="bool"   value="false"/>
    <param name="angle_compensate"    type="bool"   value="false"/>
    <param name="scan_mode"           type="string" value="Express"/>
    <param name="max_range"           type="double" value="6.0"/>
    <param name="auto_standby"        type="bool"   value="false"/>
    <param name="min_range"           type="double" value="0.15"/>
    <param name="frequency"           type="double" value="7.0"/>
    <param name="use_sim_time"         type="bool" value="false"/>
  </node>

  <!-- URDF 加载与机器人状态发布 -->
  <param name="robot_description" command="cat /home/songfei/catkin_ws/src/tracer_ros/tracer_description/urdf/tracer_v1.urdf"/>
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher">
    <param name="publish_frequency" value="100.0"/>
    <param name="use_sim_time" value="false"/>
  </node>

  <!-- Hector SLAM 建图节点 -->
  <node pkg="hector_mapping" type="hector_mapping" name="hector_mapping" output="screen">
    <!-- 坐标系设置 -->
    <param name="map_frame" value="map" />
    <param name="base_frame" value="base_link" />
    <param name="odom_frame" value="base_link" />
    
    <!-- 激光雷达参数 -->
    <param name="scan_topic" value="/scan" />
    <param name="laser_z_orientation" value="1" />
    
    <!-- 地图参数 -->
    <param name="map_resolution" value="0.05" />
    <param name="map_size" value="2048" />
    <param name="map_start_x" value="0.5" />
    <param name="map_start_y" value="0.5" />
    <param name="map_multi_res_levels" value="2" />
    
    <!-- 更新参数 -->
    <param name="update_factor_free" value="0.4" />
    <param name="update_factor_occupied" value="0.9" />
    
    <!-- 发布参数 -->
    <param name="advertise_map_service" value="true" />
    <param name="use_tf_scan_transformation" value="true" />
    <param name="use_tf_pose_start_estimate" value="false" />
    
    <!-- 地图发布频率 -->
    <param name="map_pub_period" value="2.0" />
    
    <!-- 系统参数 -->
    <param name="laser_min_dist" value="0.15" />
    <param name="laser_max_dist" value="6.0" />
  </node>

  <!-- 可选的 Hector 轨迹服务器 -->
  <!-- <node pkg="hector_trajectory_server" type="hector_trajectory_server" name="hector_trajectory_server" output="screen">
    <param name="target_frame_name" type="string" value="/map" />
    <param name="source_frame_name" type="string" value="/base_footprint" />
    <param name="trajectory_update_rate" type="double" value="4" />
    <param name="trajectory_publish_rate" type="double" value="0.25" />
  </node> -->

  <!-- RViz 可视化 -->
  <node pkg="rviz" type="rviz" name="rviz" args="-d $(find hector_slam_launch)/rviz_cfg/mapping_demo.rviz"/>
</launch>