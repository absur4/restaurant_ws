<launch>
  <!-- 加载URDF到参数服务器 -->
  <param name="robot_description" 
         command="$(find xacro)/xacro '$(find tracer_base)/urdf/handheld_laser.urdf.xacro'"/>

  <!-- 启动TF发布节点 -->
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher">
    <param name="publish_frequency" value="100.0"/>
  </node>

  <!-- 发布 map -> base_link 的静态变换 -->
  <node name="static_transform_publisher" pkg="tf" type="static_transform_publisher"
        args="0 0 0 0 0 0 map base_link 100"/>

  <!-- 启动 Hector SLAM 核心节点 -->
  <node pkg="hector_mapping" type="hector_mapping" name="hector_mapping" output="screen">
    <!-- 坐标系配置 -->
    <param name="base_frame" value="base_link"/>      
    <param name="odom_frame" value="odom"/>           
    <param name="map_frame" value="map"/>             
    <param name="scan_topic" value="/scan"/>          
    <param name="laser_frame" value="laser_link"/>    

    <!-- 建图参数（适合手持） -->
    <param name="map_resolution" value="0.05"/>       
    <param name="map_size" value="1024"/>             
    <param name="update_factor_free" value="0.3"/>
    <param name="update_factor_occupied" value="0.8"/>
    <param name="use_tf_scan_transformation" value="true"/>
    <param name="pub_map_odom_transform" value="false"/>
    <param name="use_odometry_data" value="false"/>
    <param name="pub_map_scanmatch_transform" value="true"/>
  </node>

  <!-- 启动 RViz 可视化 -->
  <node pkg="rviz" type="rviz" name="rviz" />

</launch>
