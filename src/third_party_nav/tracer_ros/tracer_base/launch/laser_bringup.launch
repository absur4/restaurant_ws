<launch>
  <!-- 加载URDF到参数服务器 -->
  <param name="robot_description" 
         command="$(find xacro)/xacro '$(find tracer_base)/urdf/handheld_laser.urdf.xacro'"/>

  <!-- 启动TF发布节点 -->
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher">
    <param name="publish_frequency" value="50.0"/>
    <param name="use_sim_time" value="false"/>
  </node>
  
  <!-- 添加base_link到odom的静态变换，解决变换缺失问题 -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="base_link_to_odom" args="0 0 0 0 0 0 odom base_link" />

  <node pkg="hector_mapping" type="hector_mapping" name="hector_mapping" output="screen">
    <!-- 坐标系配置 -->
    <param name="base_frame" value="base_link"/>      <!-- 基础坐标系 -->
    <param name="odom_frame" value="odom"/>           <!-- 启用里程计坐标系 -->
    <param name="map_frame" value="map"/>             <!-- 地图坐标系 -->
    <param name="scan_topic" value="scan"/>          <!-- 雷达数据话题 -->
    <param name="laser_frame" value="laser_link"/>    <!-- 雷达坐标系 -->

    <!-- 建图参数调整（适合手持场景） -->
    <param name="map_resolution" value="0.05"/>       <!-- 地图分辨率 -->
    <param name="map_size" value="4096"/>             <!-- 更大的地图尺寸 -->
    <param name="update_factor_free" value="0.3"/>
    <param name="update_factor_occupied" value="0.8"/>
    <param name="use_tf_scan_transformation" value="true"/>
    <param name="pub_map_odom_transform" value="true"/>
    <param name="use_sim_time" value="false"/>
    
    <!-- 手持模式下关闭里程计依赖 -->
    <param name="use_odometry_data" value="false"/>
    <param name="pub_map_scanmatch_transform" value="true"/>
    
    <!-- 添加时间同步相关参数 -->
    <param name="tf_tolerance" value="0.5"/>          <!-- 增加TF容忍度到0.5秒 -->
    <param name="map_update_interval" value="0.05"/>  <!-- 提高地图更新频率 -->
    <param name="transform_tolerance" value="0.5"/>   <!-- 变换容忍度 -->
  </node>

  <!-- 启动RViz可视化 -->
  <node pkg="rviz" type="rviz" name="rviz" />
  
  <!-- 启动雷达驱动（根据实际雷达型号修改） -->
  <node name="rplidarNode" pkg="rplidar_ros" type="rplidarNode" output="screen">
    <param name="serial_port"         type="string" value="/dev/ttyUSB0"/>
    <param name="serial_baudrate"     type="int"    value="256000"/>
    <param name="frame_id"            type="string" value="laser_link"/>
    <param name="inverted"            type="bool"   value="false"/>
    <param name="angle_compensate"    type="bool"   value="false"/>
    <!-- 使用稳定性模式 -->
    <param name="scan_mode"           type="string" value="Express"/>
    <param name="max_range"           type="double" value="6.0"/>
    <!-- 添加稳定性参数 -->
    <param name="auto_standby"        type="bool"   value="false"/>
    <param name="min_range"           type="double" value="0.15"/>
    <!-- 限制数据频率 -->
    <param name="frequency"           type="double" value="7.0"/>
    <param name="use_sim_time"         type="bool" value="false"/>
  </node>
</launch>
